# Google AI Studio — one key covers both Gemini and embeddings
# Get it at https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Supabase — from your project's API settings (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-side only. NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: tune the AI usage meter and rate-limit queue.
# Defaults match AI Studio free tier for gemini-2.5-flash (~5/min, ~250/day).
# GEMINI_RPM=5
# GEMINI_RPD=250
# GEMINI_EMBED_RPM=100
# GEMINI_QUEUE_MS=7000
# GEMINI_EMBED_QUEUE_MS=350
