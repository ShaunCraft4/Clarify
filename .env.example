# Google AI Studio — one key covers both Gemini and embeddings
# Get it at https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Supabase — from your project's API settings (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-side only. NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: tune the "AI requests left" meter to match your Gemini quota.
# Defaults assume the gemini-2.5-flash free tier (~10/min, ~250/day).
# GEMINI_RPM=10
# GEMINI_RPD=250
